# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY — защита сайта
# ═══════════════════════════════════════════════════════════════════════════════

# Отключить листинг папок, MultiViews, выполнение CGI
Options -Indexes -MultiViews -ExecCGI
DirectoryIndex index.php

# Скрыть версии Apache/PHP (server signature off)
ServerSignature Off
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header unset X-Aspnet-Version
    Header unset X-AspnetMvc-Version
    Header always unset Server
</IfModule>

# ── Блокировка прямого доступа к служебным файлам ────────────────────────────

<FilesMatch "^(_init|bootstrap|config|wp-config|settings)\.php$">
    Require all denied
</FilesMatch>

# Блокировать базы, логи, конфиги, бэкапы, исходники
<FilesMatch "\.(db|sqlite|sqlite3|json|log|txt|bak|old|swp|sql|tar|gz|zip|env|ini|yml|yaml|md|git|sh|py|pl|conf)$">
    Require all denied
</FilesMatch>

# Скрытые файлы (.git, .env, .DS_Store, .htaccess*)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Блок .htaccess/.htpasswd
<Files ".htaccess">
    Require all denied
</Files>
<Files ".htpasswd">
    Require all denied
</Files>

# Запретить доступ к папке data/ (SQLite + пароль setup)
RewriteEngine On
RewriteRule ^data(/.*)?$ - [F,L]

# ── Блокировка типичных probe-запросов (phpMyAdmin, WP, scanners) ────────────

RewriteCond %{REQUEST_URI} (?:wp-admin|wp-login|xmlrpc\.php|wp-config|wlwmanifest|wp-json|phpmyadmin|pma|myadmin|mysql|adminer|sqlmanager|dbadmin|websql|shell\.php|c99\.php|r57|upload\.php|filemanager|fckeditor|ckeditor|tinymce|/\.env|/\.git|/admin\.php$|/administrator/) [NC]
RewriteRule .* - [F,L]

# Блок SQL-injection паттернов в QUERY_STRING
RewriteCond %{QUERY_STRING} (union.*select|concat.*\(|select.*from|insert.*into|drop.*table|update.*set|benchmark\(|sleep\() [NC]
RewriteRule .* - [F,L]

# Блок XSS паттернов
RewriteCond %{QUERY_STRING} (<script|javascript:|onerror=|onload=|eval\(|alert\() [NC]
RewriteRule .* - [F,L]

# Блок directory traversal
RewriteCond %{QUERY_STRING} (\.\./|%2e%2e%2f|%2e%2e/|\.\.\\|%c0%2e%c0%2e) [NC]
RewriteRule .* - [F,L]

# ── Блокировка bad user-agents (сканеры, агрессивные боты) ──────────────────

RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|wpscan|nmap|masscan|acunetix|nessus|openvas|appscan|burp|havij|jorgee|zgrab|morfeus|fuzz|dirbuster|hydra|medusa|ncrack|ahrefs|semrush|mj12bot|dotbot|petalbot|blexbot) [NC]
RewriteRule .* - [F,L]

# Пустой User-Agent → 403 (легитимные клиенты всегда его шлют)
RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
RewriteCond %{HTTP_USER_AGENT} ^-$
RewriteRule .* - [F,L]

# Прямое обращение без Host (IP-сканы)
RewriteCond %{HTTP_HOST} ^$
RewriteRule .* - [F,L]

# ── HTTP → HTTPS (Cloudflare-aware) ──────────────────────────────────────────

RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Security headers ────────────────────────────────────────────────────────

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# ── Gzip ────────────────────────────────────────────────────────────────────

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain application/json application/xml
</IfModule>

# ── Cache статики: статика долго, HTML без кэша ─────────────────────────────

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType font/woff2 "access plus 365 days"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Лимит размера тела запроса (анти-POST-flood) — 5 MB ─────────────────────

LimitRequestBody 5242880
